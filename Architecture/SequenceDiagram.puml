@startuml SequenceDiagram
title Generic Concurrent Real-Time Pipeline - Complete Sequence Diagram

actor User

participant Main
participant ConfigReader
participant ConfigValidator
participant "Input Process\n(Input Module)" as Input
participant "Functional Core" as FC
participant "Raw Queue" as RawQ
participant "Scatter Workers\n(Parallel Core)" as Scatter
participant "Intermediate Queue" as IntQ
participant "Gather Process\n(Aggregator)" as Gather
participant "Processed Queue" as ProcQ
participant "Output Dashboard" as Output
participant "Telemetry\n(Observer Subject)" as Telemetry

== Initialization ==
User -> Main          : run main.py
Main -> ConfigReader  : load_config()
ConfigReader --> Main : config.json
Main -> ConfigValidator : validate_config(config)
ConfigValidator --> Main : validated config
Main -> RawQ     : create(max_size)
Main -> IntQ     : create(max_size)
Main -> ProcQ    : create(max_size)
Main -> Telemetry : initialize(queues)
Main -> Output   : initialize()
Telemetry -> Output : subscribe()

== Process Creation ==
Main -> Output   : start process
Main -> Gather   : start process
Main -> Scatter  : start N workers (core_parallelism)
Main -> Input    : start process
Main -> Telemetry : start monitoring thread
Main -> Output   : run()

== Data Streaming (Producer-Consumer with Backpressure) ==
loop Continuous Stream
    Input -> ConfigReader : get schema_mapping
    Input -> Input        : read row + cast types
    Input -> Input        : sleep(input_delay_seconds)
    alt RawQ FULL (Backpressure)
        Input -> RawQ : wait (blocked)
    else Space Available
        Input -> RawQ : push packet
    end
    par Parallel Workers
        Scatter -> RawQ         : consume packet
        Scatter -> ConfigReader : get secret_key
        Scatter -> FC           : verify_signature(packet, key)
        alt Valid Packet
            Scatter -> IntQ : push verified packet
        else Invalid Packet
            Scatter -> Scatter : drop packet
        end
    end
    Gather -> IntQ         : consume verified packet
    Gather -> ConfigReader : get window size
    Gather -> Gather       : resequence stream (if needed)
    Gather -> FC           : compute_average(window)
    Gather -> ProcQ        : push processed packet
    Output -> ProcQ        : read processed data
    Output -> Output       : update graphs (value + average)
end

== Telemetry Monitoring (Observer Pattern) ==
loop Continuous Monitoring
    Telemetry -> RawQ     : qsize()
    Telemetry -> IntQ     : qsize()
    Telemetry -> ProcQ    : qsize()
    Telemetry -> Telemetry : compute queue ratios
    Telemetry -> Output   : notify(status)
    Output -> Output      : update colors\n(Green / Yellow / Red)
end

== Graceful Termination ==
Input   -> RawQ    : send END signal (sentinel)
Scatter -> RawQ    : receive END
Scatter -> IntQ    : forward END
Gather  -> IntQ    : receive END
Gather  -> ProcQ   : forward END
Output  -> ProcQ   : receive END
Output  -> Output  : stop rendering
User    -> Output  : close dashboard
Output  -> Telemetry : stop monitoring

@enduml
